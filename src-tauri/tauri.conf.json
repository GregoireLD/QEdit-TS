{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QEdit",
  "version": "3.0.60",
  "identifier": "com.qedit.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QEdit",
        "width": 760,
        "height": 500,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["qst", "qpv3"],
        "name": "PSO Quest",
        "description": "Phantasy Star Online Quest File",
        "role": "Editor"
      },
      {
        "ext": ["bin"],
        "name": "Binary Quest File",
        "description": "PSO Quest Binary",
        "role": "Viewer"
      }
    ]
  }
}
